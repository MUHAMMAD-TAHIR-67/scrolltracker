<?xml version="1.0" encoding="utf-8"?>
<!--
  ScrollTracker only needs structural signals, not screen content:
  - typeWindowStateChanged: app foreground changes (which app is now active)
  - typeViewScrolled: scroll gestures inside the foreground app
  - typeWindowContentChanged: RecyclerView/ViewPager child swaps (new video)

  canRetrieveWindowContent is left FALSE. We never call
  getRootInActiveWindow() or traverse the node tree for text - we only read
  the resource-id / content-description of the node that fired the event,
  which Android already includes on the AccessibilityEvent itself.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged|typeViewScrolled|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagReportViewIds|flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="false"
    android:notificationTimeout="100"
    android:packageNames="com.instagram.android,com.google.android.youtube,com.zhiliaoapp.musically,com.ss.android.ugc.trill,com.snapchat.android"
    android:description="@string/accessibility_service_description" />
